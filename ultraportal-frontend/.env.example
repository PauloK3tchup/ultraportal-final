# Configuração da URL da API do Backend

# URL completa da API (prioritária)
# Se definido, sobrescreve as outras configurations
# Exemplo: https://sua-ec2.com:30080
# VITE_API_URL=http://localhost:8000

# Porta do Backend (usado apenas se VITE_API_URL não estiver definido)
# Padrão: 30080 (para AWS)
# Em desenvolvimento local, deixe em branco ou use 8000
# VITE_API_PORT=30080

# Nota: Estas variáveis devem ser definidas:
# 1. No arquivo .env local para desenvolvimento
# 2. No docker-compose.yml para ambiente containerizado
# 3. Como variáveis de ambiente na EC2 ao iniciar o container
